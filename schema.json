{
  "type": "component",
  "metadata": {
    "svelteMajor": 5
  },
  "schema": {
    "name": "AutocompleteSearch",
    "friendlyName": "Autocomplete Search",
    "description": "Mobile-first searchable autocomplete. Calls a Budibase query directly — no premium data provider needed.",
    "icon": "Search",
    "hasChildren": false,
    "settings": [
      {
        "type": "text",
        "key": "queryId",
        "label": "Query ID (direct — takes priority)"
      },
      {
        "type": "text",
        "key": "queryName",
        "label": "Query Name (auto-lookup if ID blank)",
        "defaultValue": "qry_SearchCustomers"
      },
      {
        "type": "text",
        "key": "searchParam",
        "label": "Search Binding Name",
        "defaultValue": "search"
      },
      {
        "type": "text",
        "key": "placeholder",
        "label": "Placeholder Text",
        "defaultValue": "Type at least 3 characters to search…"
      },
      {
        "type": "text",
        "key": "displayField",
        "label": "Primary Display Field",
        "defaultValue": "BName"
      },
      {
        "type": "text",
        "key": "cityField",
        "label": "City Field",
        "defaultValue": "BCity"
      },
      {
        "type": "text",
        "key": "stateField",
        "label": "State Field",
        "defaultValue": "BST"
      },
      {
        "type": "text",
        "key": "zipField",
        "label": "Zip Field",
        "defaultValue": "BZip10"
      },
      {
        "type": "text",
        "key": "acctField",
        "label": "Output: Account # Column",
        "defaultValue": "Acct"
      },
      {
        "type": "text",
        "key": "bNameField",
        "label": "Output: Business Name Column",
        "defaultValue": "BName"
      },
      {
        "type": "text",
        "key": "labCodeField",
        "label": "Output: Lab Code Column",
        "defaultValue": "LabCode"
      },
      {
        "type": "text",
        "key": "taxCodeField",
        "label": "Output: Tax Code Column",
        "defaultValue": "TaxCode"
      },
      {
        "type": "text",
        "key": "taxExemptField",
        "label": "Output: Tax Exempt Column",
        "defaultValue": "TaxExempt"
      },
      {
        "type": "number",
        "key": "minChars",
        "label": "Minimum Characters Before Search",
        "defaultValue": 3
      },
      {
        "type": "number",
        "key": "debounceMs",
        "label": "Debounce Delay (ms)",
        "defaultValue": 300
      },
      {
        "type": "boolean",
        "key": "showAddNew",
        "label": "Show 'Add New' Option",
        "defaultValue": true
      },
      {
        "type": "text",
        "key": "addNewLabel",
        "label": "'Add New' Button Label",
        "defaultValue": "Customer not found — Add New"
      },
      {
        "type": "color",
        "key": "primaryColor",
        "label": "Accent / Primary Colour",
        "defaultValue": "#6366f1"
      },
      {
        "type": "color",
        "key": "inputBg",
        "label": "Input Background",
        "defaultValue": "#ffffff"
      },
      {
        "type": "color",
        "key": "dropdownBg",
        "label": "Dropdown Background",
        "defaultValue": "#ffffff"
      },
      {
        "type": "color",
        "key": "borderColor",
        "label": "Border Colour",
        "defaultValue": "#e2e8f0"
      },
      {
        "type": "color",
        "key": "textColor",
        "label": "Text Colour",
        "defaultValue": "#1e293b"
      },
      {
        "type": "color",
        "key": "mutedColor",
        "label": "Muted / Secondary Text Colour",
        "defaultValue": "#64748b"
      },
      {
        "type": "number",
        "key": "inputHeight",
        "label": "Input Height (px)",
        "defaultValue": 48
      },
      {
        "type": "number",
        "key": "borderRadius",
        "label": "Border Radius (px)",
        "defaultValue": 10
      },
      {
        "type": "number",
        "key": "fontSize",
        "label": "Font Size (px)",
        "defaultValue": 15
      },
      {
        "type": "number",
        "key": "dropdownMaxHeight",
        "label": "Dropdown Max Height (px)",
        "defaultValue": 320
      },
      {
        "type": "event",
        "key": "onChange",
        "label": "On Selection",
        "context": [
          { "label": "Account Number", "key": "Acct" },
          { "label": "Business Name", "key": "BName" },
          { "label": "Lab Code", "key": "LabCode" },
          { "label": "Tax Code", "key": "TaxCode" },
          { "label": "Tax Exempt", "key": "TaxExempt" }
        ]
      },
      {
        "type": "event",
        "key": "onAddNewCustomer",
        "label": "On Add New Customer"
      }
    ]
  }
}
